{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "../../out/services/api",
    "types": [
      "bun"
    ],
    "composite": true,
    "tsBuildInfoFile": "../../out/tsbuildinfo/api.tsbuildinfo",
    "paths": {
      "@vibe-tavern/api-contracts": [
        "../../packages/api-contracts/src/index.ts"
      ],
      "@vibe-tavern/db": [
        "../../packages/db/src/index.ts"
      ],
      "@vibe-tavern/domain": [
        "../../packages/domain/src/index.ts"
      ],
      "@vibe-tavern/import-export": [
        "../../packages/import-export/src/index.ts"
      ],
      "@vibe-tavern/prompt-pipeline": [
        "../../packages/prompt-pipeline/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "references": [
    {
      "path": "../../packages/domain"
    },
    {
      "path": "../../packages/api-contracts"
    },
    {
      "path": "../../packages/prompt-pipeline"
    },
    {
      "path": "../../packages/db"
    },
    {
      "path": "../../packages/import-export"
    }
  ]
}
