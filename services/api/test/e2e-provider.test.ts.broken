/**
 * Test 2 — Provider profile CRUD + model fetch
 *
 * Covers:
 *   1. Create provider profile with NanoGPT key + endpoint
 *   2. Activate the profile
 *   3. Verify round-trip of all canonical field names
 *      (providerPreset, frequencyPenalty, stopSequences as string[], topA)
 *   4. Fetch available models from NanoGPT endpoint
 *   5. Update profile fields
 *   6. Delete profile
 *
 * Uses real NanoGPT API key from mcp/.env — test is network-dependent.
 */
import { describe, test as testFn,
 it, expect, afterAll, beforeAll } from "bun:test";
import { createTestServer, json } from "./helpers/e2e-server.js";
import type { TestServer } from "./helpers/e2e-server.js";

let server: TestServer;

const NANOGPT_API_KEY = "sk-nano-c762b8b9-9d14-411e-8151-bf6ef9074bdd";
const NANOGPT_BASE_URL = "https://nano-gpt.com/api/v1";

beforeAll(async () => {
  server = await createTestServer();
});

afterAll(async () => {
  await server.cleanup();
});

// ─── Types ─────────────────────────────────────────────────────────────────

interface ProviderProfile {
  id: string;
  name: string;
  providerPreset: string;
  endpoint: string;
  hasStoredApiKey: boolean;
  defaultModel: string | null;
  contextBudget: number | null;
  temperature: number;
  topP: number;
  minP: number;
  topK: number;
  topA: number;
  frequencyPenalty: number;
  presencePenalty: number;
  repetitionPenalty: number;
  maxTokens: number;
  stopSequences: string[];
  seed: number | null;
  reasoningEffort: string;
  streamResponse: boolean;
}

// ─── Tests ─────────────────────────────────────────────────────────────────

describe.skip("Provider profile CRUD with NanoGPT", () => {
  let profileId: string;

  it("creates a provider profile with all canonical fields", async () => {
    const res = await server.api("/api/providers", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        name: "NanoGPT Test",
        providerPreset: "openai_compat",
        endpoint: NANOGPT_BASE_URL,
        apiKey: NANOGPT_API_KEY,
        defaultModel: "moonshotai/kimi-k2.5",
        contextBudget: 128000,
        temperature: 0.8,
        topP: 0.95,
        minP: 0.05,
        topK: 40,
        topA: 0.1,
        frequencyPenalty: 0.0,
        presencePenalty: 0.0,
        repetitionPenalty: 1.0,
        maxTokens: 4096,
        stopSequences: ["\n\n\n", "<|endoftext|>"],
        seed: "42",
        reasoningEffort: "auto",
        streamResponse: true,
      }),
    });

    const profile = await json<ProviderProfile>(res);
    expect(profile.id).toBeTruthy();
    expect(profile.name).toBe("NanoGPT Test");
    expect(profile.providerPreset).toBe("openai_compat");
    expect(profile.endpoint).toBe(NANOGPT_BASE_URL);
    expect(profile.hasStoredApiKey).toBe(true);
    expect(profile.temperature).toBe(0.8);
    expect(profile.topP).toBe(0.95);
    expect(profile.minP).toBe(0.05);
    expect(profile.topK).toBe(40);
    expect(profile.topA).toBe(0.1);
    expect(profile.frequencyPenalty).toBe(0.0);
    expect(profile.presencePenalty).toBe(0.0);
    expect(profile.repetitionPenalty).toBe(1.0);
    expect(profile.maxTokens).toBe(4096);
    expect(profile.stopSequences).toEqual(["\n\n\n", "<|endoftext|>"]);
    expect(profile.seed).toBe("42");
    expect(profile.reasoningEffort).toBe("auto");
    expect(profile.streamResponse).toBe(true);

    profileId = profile.id;
  });

  it("reads the profile back via GET /api/providers/:id", async () => {
    const profile = await json<ProviderProfile>(
      await server.api(`/api/providers/${profileId}`),
    );
    expect(profile.id).toBe(profileId);
    expect(profile.stopSequences).toEqual(["\n\n\n", "<|endoftext|>"]);
    expect(profile.topA).toBe(0.1);
    expect(profile.hasStoredApiKey).toBe(true);
  });

  it("lists the profile in GET /api/providers", async () => {
    const profiles = await json<ProviderProfile[]>(
      await server.api("/api/providers"),
    );
    expect(profiles.length).toBe(1);
    expect(profiles[0].id).toBe(profileId);
  });

  it("activates the profile", async () => {
    const profile = await json<ProviderProfile>(
      await server.api(`/api/providers/${profileId}/activate`, {
        method: "POST",
      }),
    );
    expect(profile.id).toBe(profileId);
  });

  it("updates individual sampler fields", async () => {
    const updated = await json<ProviderProfile>(
      await server.api(`/api/providers/${profileId}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          temperature: 0.5,
          frequencyPenalty: 0.3,
          presencePenalty: 0.2,
          stopSequences: ["<stop>", "---"],
        }),
      }),
    );
    expect(updated.temperature).toBe(0.5);
    expect(updated.frequencyPenalty).toBe(0.3);
    expect(updated.presencePenalty).toBe(0.2);
    expect(updated.stopSequences).toEqual(["<stop>", "---"]);
    // Unchanged fields stay
    expect(updated.topA).toBe(0.1);
    expect(updated.repetitionPenalty).toBe(1.0);
  });

  it("fetches models from NanoGPT endpoint", async () => {
    const res = await server.api(`/api/providers/${profileId}/models`, {
      method: "POST",
    });
    const data = await json<{ models: Array<{ id: string; label?: string }> }>(res);
    expect(Array.isArray(data.models)).toBe(true);
    // NanoGPT should have at least some models
    if (data.models.length > 0) {
      expect(data.models[0].id).toBeTruthy();
    }
  });

  it("deletes the profile", async () => {
    const res = await server.api(`/api/providers/${profileId}`, {
      method: "DELETE",
    });
    expect(res.ok).toBe(true);

    const profiles = await json<ProviderProfile[]>(
      await server.api("/api/providers"),
    );
    expect(profiles.length).toBe(0);
  });
});
