<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#FF1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌴"
        android:textSize="64sp"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vibe Tavern"
        android:textSize="28sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Step 1: Install Termux"
        android:textSize="16sp"
        android:textColor="#A0A0B0"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Vibe Tavern needs Termux to run the server on your phone.\n\n⚠ IMPORTANT: Install from F-Droid, NOT the Play Store.\nThe Play Store version is outdated and won't work."
        android:textSize="14sp"
        android:textColor="#CCCCDD"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btn_install_termux"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Install Termux from F-Droid"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        style="@style/Widget.VibeTavern.Button.Primary" />

    <Button
        android:id="@+id/btn_check_again"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="I've installed it — continue"
        android:textSize="14sp"
        style="@style/Widget.VibeTavern.Button.Secondary" />

</LinearLayout>
