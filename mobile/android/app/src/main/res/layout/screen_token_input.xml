<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#FF1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌴"
        android:textSize="64sp"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Step 3: GitHub Access"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Create a token on GitHub (on your computer):\nSettings → Developer settings → Personal access tokens → Tokens (classic)\n→ Generate new token (classic) → check &quot;repo&quot; → Generate\n\nPaste the token here:"
        android:textSize="14sp"
        android:textColor="#CCCCDD"
        android:gravity="start"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/token_input"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="ghp_..."
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:textColorHint="#555566"
        android:background="@drawable/token_input_bg"
        android:inputType="text"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_save_token"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Save &amp; Continue"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        style="@style/Widget.VibeTavern.Button.Primary" />

    <Button
        android:id="@+id/btn_skip_token"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Skip (public repo only)"
        android:textSize="14sp"
        style="@style/Widget.VibeTavern.Button.Secondary" />

</LinearLayout>
