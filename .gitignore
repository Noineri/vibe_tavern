# Dependencies
node_modules/
**/node_modules/

# Build output — all artefacts go to out/
out/
**/dist/
installer/output/

# Packaged binaries / archives (generated, never tracked)
*.exe
*.msi
*.dmg
*.pkg
*.AppImage
*.tar
*.tar.gz
*.tgz
*.zip
*.7z

# Lock files (migrated to bun.lock)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Local runtime data
data/
*.sqlite
*.sqlite-*
*.db
*.db-*

# Logs
logs/
*.log

# Secrets and local environment
.env
.env.*
!.env.example

# OS/editor noise
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/

# Temporary files
*.tmp
*.temp
.pi/

# Drizzle generated output (dev-only)
drizzle-generated/

# Planning repo (separate repository)
vibe_tavern_plan/

# Runtime token cache
.tokensave

# Test temp directories
services/api/tmp-test-*/

# Source runtime assets under services/api/assets/ are intentionally tracked.
