# Dependencies
node_modules/
**/node_modules/

# Build output — all artefacts go to out/
out/
**/dist/
installer/output/

# Packaged binaries / archives (generated, never tracked)
*.exe
*.msi
*.dmg
*.pkg
*.AppImage
*.tar
*.tar.gz
*.tgz
*.zip
*.7z

# Local runtime data
data/
*.sqlite
*.sqlite-*
*.db
*.db-*

# Logs
logs/
*.log

# Secrets and local environment
.env
.env.*
!.env.example
docker-compose.override.yml

# OS/editor noise
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/

# Temporary files
*.tmp
*.temp
.pi/
.omo/

# Drizzle generated output (dev-only)
drizzle-generated/

# Planning repo (separate repository)
vibe_tavern_plan/

# Runtime token cache
.tokensave

# Test temp directories
services/api/tmp-test-*/

# Source runtime assets under services/api/assets/ are intentionally tracked.

# Android / Gradle
mobile/android/local.properties
mobile/android/.gradle/
mobile/android/**/build/
*.apk
*.aab

# Install hash cache (skip-install optimization)
.install-hash
