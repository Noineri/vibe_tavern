{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "../..",
    "outDir": "dist",
    "jsx": "react-jsx",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "bun",
      "vite/client"
    ],
    "paths": {
      "@rp-platform/api": [
        "../../services/api/src/index.ts"
      ],
      "@rp-platform/api-contracts": [
        "../../packages/api-contracts/src/index.ts"
      ],
      "@rp-platform/db": [
        "../../packages/db/src/index.ts"
      ],
      "@rp-platform/domain": [
        "../../packages/domain/src/index.ts"
      ],
      "@rp-platform/prompt-pipeline": [
        "../../packages/prompt-pipeline/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "vite.config.ts"
  ]
}
