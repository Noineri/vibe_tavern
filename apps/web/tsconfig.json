{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "../../out/apps/web-types",
    "jsx": "react-jsx",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "bun",
      "vite/client"
    ],
    "composite": true,
    "tsBuildInfoFile": "../../out/tsbuildinfo/web.tsbuildinfo",
    "paths": {
      "@vibe-tavern/api": [
        "../../services/api/src/index.ts"
      ],
      "@vibe-tavern/api-contracts": [
        "../../packages/api-contracts/src/index.ts"
      ],
      "@vibe-tavern/db": [
        "../../packages/db/src/index.ts"
      ],
      "@vibe-tavern/domain": [
        "../../packages/domain/src/index.ts"
      ],
      "@vibe-tavern/prompt-pipeline": [
        "../../packages/prompt-pipeline/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts"
  ],
  "references": [
    {
      "path": "../../packages/domain"
    },
    {
      "path": "../../packages/api-contracts"
    },
    {
      "path": "../../packages/prompt-pipeline"
    },
    {
      "path": "../../packages/db"
    },
    {
      "path": "../../services/api"
    }
  ]
}
