{
  "name": "rp-platform",
  "version": "0.1.5",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "build:api-stack": "bun run --filter @rp-platform/domain build && bun run --filter @rp-platform/prompt-pipeline build && bun run --filter @rp-platform/db build && bun run --filter @rp-platform/import-export build && bun run --filter @rp-platform/api build",
    "build:prod": "bun scripts/build.ts api-stack",
    "build:standalone": "bun scripts/build-standalone.ts",
    "build:installer": "bun scripts/build-installer.ts",
    "dev": "bun ./scripts/dev-supervisor.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "check": "bun run typecheck && bun run test",
    "dev:api": "bun run --filter @rp-platform/api dev",
    "dev:web": "bun run --filter @rp-platform/web dev",
    "db:push": "bun run --filter @rp-platform/db db:push"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
