{
  "name": "vibe-tavern",
  "version": "0.3.5",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "lightningcss",
    "rolldown"
  ],
  "scripts": {
    "build": "bun run build:api-stack && bun run --filter @vibe-tavern/web build",
    "build:api-stack": "bun scripts/build.ts api-stack",
    "build:prod": "bun scripts/build.ts api-stack",
    "build:standalone": "bun scripts/build-standalone.ts",
    "build:android-arm64": "bun scripts/build-android-arm64.ts",
    "build:linux-dist": "bun scripts/build-linux-dist.ts",
    "build:windows-dist": "bun scripts/build-windows-dist.ts",
    "build:installer": "bun scripts/build-installer.ts",
    "dev": "bun run build && bun services/api/src/server/prod-server.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "test:parallel": "bun test --parallel",
    "i18n:check": "bun scripts/i18n-check.ts",
    "check": "bun run typecheck && bun run test && bun run i18n:check",
    "dev:api": "bun run --filter @vibe-tavern/api dev",
    "dev:web": "bun run --filter @vibe-tavern/web dev",
    "db:generate": "bun run --filter @vibe-tavern/db db:generate",
    "db:push": "bun run --filter @vibe-tavern/db db:push"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pngjs": "^6.0.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "hono": "^4.12.25",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.0.9",
    "zustand": "^5.0.14"
  }
}
